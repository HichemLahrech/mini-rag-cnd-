# Copie ce fichier en .env et remplis les valeurs souhaitées (facultatif).
# Le service fonctionne sans .env : ANTHROPIC_API_KEY et API_KEY sont
# optionnelles (voir docker-compose.yml et api.py).

# Nécessaire uniquement si tu veux utiliser provider="claude" dans /query
ANTHROPIC_API_KEY=

# Nécessaire uniquement si tu veux protéger l'API par une clé (header X-API-Key)
API_KEY=
